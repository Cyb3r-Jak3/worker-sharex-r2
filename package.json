{
	"name": "sharex-r2-cloudflare-workers",
	"version": "2.0.0",
	"private": true,
	"license": "MIT",
	"main": "index.js",
	"scripts": {
		"build": "esbuild src/index.ts --format=esm --platform=neutral --minify --bundle --sourcemap --main-fields=browser,module,main --outfile=dist/index.mjs",
		"dev:remote": "pnpm wrangler dev --remote",
		"dev": "wrangler dev",
		"lint": "eslint \"src/**/*.{js,mjs,ts}\"",
		"lint:js:fix": "eslint \"src/**/*.{js,mjs,ts}\" --fix",
		"deploy": "wrangler deploy",
		"test": "pnpm run lint"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "^0.18.4",
		"@eslint/eslintrc": "^3.3.6",
		"@eslint/js": "^10.0.1",
		"@typescript-eslint/eslint-plugin": "8.64.0",
		"@typescript-eslint/parser": "8.64.0",
		"esbuild": "0.28.1",
		"eslint": "10.7.0",
		"eslint-plugin-unicorn": "72.0.0",
		"itty-router": "5.0.24",
		"render2": "1.5.1",
		"typescript": "6.0.3",
		"vitest": "4.1.10",
		"wrangler": "4.110.0"
	},
	"engines": {
		"node": ">=24",
		"pnpm": ">=11"
	},
	"dependencies": {
		"@cloudflare/workers-types": "^5.20260715.1"
	}
}
